# ========================================
# IronAI — Environment Variables
# Copy this file to server/.env for local dev
# Add these to Vercel dashboard for production
# ========================================

# --- Server ---
PORT=3000

# --- Database (local MySQL) ---
DB_HOST=localhost
DB_USER=ironai_user
DB_PASSWORD=your_db_password
DB_NAME=ironai

# --- Or use a single DATABASE_URL (PlanetScale / Aiven / cloud MySQL) ---
# DATABASE_URL=mysql://user:password@host:port/database

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_random_64_byte_hex_string

# --- AI (DeepSeek / OpenAI compatible) ---
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_deepseek_api_key
